f='Tempted in Every Respect: Christ, the Spirit, and the Proclivity to Sin.md'
w=$(
  <"$f" sed -nr               \
    -e'/Bibliography$/q'      \
    -e's/^(sub)?title: //'    \
    -e's/^(author|date):.*//' \
    -e's,</?\w[^>]*>,,g'      \
    -e's/^#+ //'              \
    -e'/^[^-]/p'              |
  wc -w
)
n=${#w}
i=0
while true; do
  echo -n ${w:$i:1}
  i=$((i + 1))
  [ $i -eq $n ] && break;
  [ $(((n - i + 1) % 3)) -eq 1 ] && echo -n ,
done
echo
